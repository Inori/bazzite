#!/usr/bin/bash
set -euo pipefail

BASE_MOUNT_DIR="/run/media/bazzite-auto"
mkdir -p "$BASE_MOUNT_DIR"

PRIMARY_UID="$(awk -F: '$3 >= 1000 && $3 < 60000 { print $3; exit }' /etc/passwd || true)"
PRIMARY_GID="$(awk -F: '$3 >= 1000 && $3 < 60000 { print $4; exit }' /etc/passwd || true)"
PRIMARY_UID="${PRIMARY_UID:-1000}"
PRIMARY_GID="${PRIMARY_GID:-1000}"

sanitize_name() {
    local value="$1"
    value="$(printf '%s' "$value" | tr -cs '[:alnum:]._-' '_')"
    value="${value#_}"
    value="${value%_}"
    printf '%s' "${value:-volume}"
}

while IFS=$'\t' read -r DEV TYPE FSTYPE UUID LABEL MOUNTPOINT; do
    [[ -z "$DEV" || -z "$FSTYPE" ]] && continue

    case "$TYPE" in
        part|disk) ;;
        *) continue ;;
    esac

    case "$FSTYPE" in
        ntfs|ntfs3|exfat) ;;
        *) continue ;;
    esac

    [[ -n "$MOUNTPOINT" ]] && continue
    findmnt -rn -S "$DEV" >/dev/null 2>&1 && continue

    NAME_SOURCE="$LABEL"
    [[ -z "$NAME_SOURCE" ]] && NAME_SOURCE="$UUID"
    [[ -z "$NAME_SOURCE" ]] && NAME_SOURCE="$(basename "$DEV")"

    SAFE_NAME="$(sanitize_name "$NAME_SOURCE")"
    TARGET_DIR="$BASE_MOUNT_DIR/$SAFE_NAME"
    INDEX=1
    while [[ -e "$TARGET_DIR" ]] && ! mountpoint -q "$TARGET_DIR"; do
        TARGET_DIR="$BASE_MOUNT_DIR/${SAFE_NAME}_$INDEX"
        INDEX=$((INDEX + 1))
    done

    mkdir -p "$TARGET_DIR"

    if [[ "$FSTYPE" == "exfat" ]]; then
        OPTS="rw,uid=${PRIMARY_UID},gid=${PRIMARY_GID},umask=022"
        if ! mount -t exfat -o "$OPTS" "$DEV" "$TARGET_DIR"; then
            rmdir "$TARGET_DIR" 2>/dev/null || true
        fi
    else
        OPTS="rw,uid=${PRIMARY_UID},gid=${PRIMARY_GID},umask=022,windows_names"
        if ! mount -t ntfs3 -o "$OPTS" "$DEV" "$TARGET_DIR"; then
            rmdir "$TARGET_DIR" 2>/dev/null || true
        fi
    fi
done < <(
    lsblk -Jpo NAME,TYPE,FSTYPE,UUID,LABEL,MOUNTPOINT \
      | jq -r '.. | objects | select(has("name")) | [(.name // ""), (.type // ""), (.fstype // ""), (.uuid // ""), (.label // ""), (.mountpoint // "")] | @tsv'
)
