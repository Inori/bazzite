<%page args="root"/>
<%
import os
import shutil
import glob

# ==============================================================================
# PART 1: 准备 Initrd 需要的文件 (NTFS3 支持)
# ==============================================================================

# 1. 创建 mount.ntfs 脚本 (NTFS3 Wrapper)
mount_ntfs_content = """#!/bin/sh
# Try to locate a usable mount binary.
if command -v mount >/dev/null 2>&1; then
    MNT="$(command -v mount)"
elif [ -x /usr/bin/mount ]; then
    MNT="/usr/bin/mount"
elif [ -x /bin/mount ]; then
    MNT="/bin/mount"
else
    MNT="mount"
fi
exec "$MNT" -t ntfs3 "$@"
"""

# 写入 /usr/sbin/mount.ntfs
sbin_path = os.path.join(root, "usr/sbin/mount.ntfs")
if not os.path.exists(os.path.dirname(sbin_path)):
    os.makedirs(os.path.dirname(sbin_path))

with open(sbin_path, "w") as f:
    f.write(mount_ntfs_content)
os.chmod(sbin_path, 0o755)

# 2. 创建 modules-load 配置
mod_conf_path = os.path.join(root, "etc/modules-load.d/10-bazzite-ntfs3.conf")
if not os.path.exists(os.path.dirname(mod_conf_path)):
    os.makedirs(os.path.dirname(mod_conf_path))

with open(mod_conf_path, "w") as f:
    f.write("ntfs3\nloop\niso9660\nsr_mod\n")

# 3. 创建 Dracut 配置 (让 dracut 把上述文件吸入 initrd)
dracut_conf_path = os.path.join(root, "etc/dracut.conf.d/10-bazzite-installer-ntfs3.conf")
if not os.path.exists(os.path.dirname(dracut_conf_path)):
    os.makedirs(os.path.dirname(dracut_conf_path))

with open(dracut_conf_path, "w") as f:
    f.write('add_drivers+=" ntfs3 loop iso9660 sr_mod "\n')
    f.write('install_items+=" /usr/sbin/mount.ntfs /etc/modules-load.d/10-bazzite-ntfs3.conf "\n')


# ==============================================================================
# PART 2: 准备 Blivet Patch
# ==============================================================================

# 2.1 复制 Patch 文件
workspace_patch = "/github/workspace/installer/patches/blivet-loop-partition.patch"
dest_patch = os.path.join(root, "tmp/blivet.patch")

if not os.path.exists(os.path.dirname(dest_patch)):
    os.makedirs(os.path.dirname(dest_patch))

if os.path.exists(workspace_patch):
    shutil.copy(workspace_patch, dest_patch)
else:
    print(f"WARNING: Patch file not found at {workspace_patch}")

# 2.2 创建 Patch 应用脚本 (apply_patch.sh)
apply_patch_script = """#!/bin/sh
set -e

echo "DEBUG: Current Python version: $(python3 --version)"

# 查找 blivet 目录 (优先匹配 python3.14)
echo "DEBUG: Searching for blivet directory..."
BLIVET_DIR=$(find /usr/lib /usr/lib64 -name "blivet" -type d 2>/dev/null | grep "python3.14" | head -n 1)

# 如果没找到 3.14，尝试任意 python3
if [ -z "$BLIVET_DIR" ]; then
    echo "WARNING: python3.14 version not found, searching generically..."
    BLIVET_DIR=$(find /usr/lib /usr/lib64 -name "blivet" -type d 2>/dev/null | grep "python3" | head -n 1)
fi

if [ -z "$BLIVET_DIR" ]; then
    echo "ERROR: blivet directory not found!"
    ls -R /usr/lib/python3* 2>/dev/null | grep blivet || true
    exit 1
fi

echo "DEBUG: Found blivet at: $BLIVET_DIR"
SITE_PACKAGES=$(dirname "$BLIVET_DIR")

echo "DEBUG: Applying patch to site-packages: $SITE_PACKAGES"
patch -d "$SITE_PACKAGES" -p1 -i /tmp/blivet.patch

echo "DEBUG: Recompiling python bytecode..."
python3 -m compileall -q "$BLIVET_DIR"

echo "DEBUG: Patch applied successfully."
"""

# 写入脚本到 chroot 的 /tmp
script_path = os.path.join(root, "tmp/apply_patch.sh")
with open(script_path, "w") as f:
    f.write(apply_patch_script)
os.chmod(script_path, 0o755)

%>

## ==============================================================================
## PART 3: Lorax 指令 (在 chroot 环境执行)
## ==============================================================================

# 1. 安装 patch 工具
runcmd dnf install -y patch

# 2. 执行补丁脚本
# 注意：直接调用脚本文件可能因文件系统挂载选项(noexec)或路径查找问题而失败。
# 最稳妥的方式是显式调用 shell 来执行脚本。
runcmd sh /tmp/apply_patch.sh

# 3. 清理
runcmd dnf remove -y patch
runcmd rm /tmp/blivet.patch
runcmd rm /tmp/apply_patch.sh
