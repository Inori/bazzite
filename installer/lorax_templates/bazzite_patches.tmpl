<%page args="root"/>
<%
import os
import glob
import re

# ==============================================================================
# PART 1: 准备 Initrd 需要的文件 (NTFS3 支持)
# ==============================================================================

# 1. 创建 modules-load 配置
mod_conf_path = os.path.join(root, "etc/modules-load.d/early.conf")
if not os.path.exists(os.path.dirname(mod_conf_path)):
    os.makedirs(os.path.dirname(mod_conf_path))

with open(mod_conf_path, "w") as f:
    f.write("ntfs3\nloop\niso9660\nsr_mod\n")

# 3. 创建 Dracut 配置 (让 dracut 把上述文件吸入 initrd)
dracut_conf_path = os.path.join(root, "etc/dracut.conf.d/10-bazzite-installer-ntfs3.conf")
if not os.path.exists(os.path.dirname(dracut_conf_path)):
    os.makedirs(os.path.dirname(dracut_conf_path))

with open(dracut_conf_path, "w") as f:
    f.write('add_drivers+=" ntfs3 loop iso9660 sr_mod "\n')
    f.write('install_items+=" /usr/sbin/mount.ntfs /etc/modules-load.d/early.conf "\n')


# ==============================================================================
# PART 2: 手动修改 Blivet 源码 (Python 字符串替换)
# ==============================================================================

# 查找 blivet 目录 (在 install.img root 中)
# 我们需要处理 root 前缀，并查找真实的 blivet 路径
blivet_root = None
search_paths = [
    os.path.join(root, "usr/lib64/python3.*/site-packages/blivet"),
    os.path.join(root, "usr/lib/python3.*/site-packages/blivet")
]

for pattern in search_paths:
    found = glob.glob(pattern)
    if found:
        blivet_root = found[0]
        break

if not blivet_root:
    print("ERROR: Could not find blivet directory in install tree!")
    # 这里我们也可以抛出异常来终止构建
    # raise RuntimeError("Blivet directory not found")
else:
    print(f"Found blivet at: {blivet_root}")

    # --------------------------------------------------------------------------
    # 2.1 修改 blivet/devices/loop.py
    # --------------------------------------------------------------------------
    loop_py_path = os.path.join(blivet_root, "devices/loop.py")
    if os.path.exists(loop_py_path):
        with open(loop_py_path, "r") as f:
            content = f.read()
        
        # 目标: 修改 LoopDevice 类定义
        # 原文:
        # class LoopDevice(StorageDevice):
        #     """ A loop device. """
        #     _type = "loop"
        #     _external_dependencies = ...
        
        # 替换为:
        # class LoopDevice(StorageDevice):
        #     """ A loop device.
        #
        #     Treated as a partitionable disk so that partition devices like
        #     loopNp1/loopNp2 can be represented as normal PartitionDevice
        #     instances (useful for loop-backed disk images).
        #     """
        #     _type = "loop"
        #     _partitionable = True
        #     _is_disk = True
        #     _external_dependencies = ...
        
        # 使用简单的字符串替换。为了稳健，我们替换类头和 docstring。
        old_str = '    """ A loop device. """\n    _type = "loop"'
        new_str = '    """ A loop device.\n\n    Treated as a partitionable disk so that partition devices like\n    loopNp1/loopNp2 can be represented as normal PartitionDevice\n    instances (useful for loop-backed disk images).\n    """\n    _type = "loop"\n    _partitionable = True\n    _is_disk = True'
        
        if old_str in content:
            new_content = content.replace(old_str, new_str)
            with open(loop_py_path, "w") as f:
                f.write(new_content)
            print("Successfully patched blivet/devices/loop.py")
        else:
            print("WARNING: Could not find target string in blivet/devices/loop.py. Patch may be already applied or file changed.")
    else:
        print(f"WARNING: {loop_py_path} does not exist.")


    # --------------------------------------------------------------------------
    # 2.2 修改 blivet/populator/helpers/loop.py
    # --------------------------------------------------------------------------
    helper_loop_py_path = os.path.join(blivet_root, "populator/helpers/loop.py")
    if os.path.exists(helper_loop_py_path):
        with open(helper_loop_py_path, "r") as f:
            content = f.read()

        # 目标: 修改 match 方法
        # 原文:
        #     @classmethod
        #     def match(cls, data):
        #         return udev.device_is_loop(data)
        
        # 替换为:
        #     @classmethod
        #     def match(cls, data):
        #         """Match only whole loop devices, not their partitions.
        #
        #         For example, match "loop2", but let PartitionDevicePopulator
        #         handle "loop2p1" etc.
        #         """
        #         return udev.device_is_loop(data) and not udev.device_is_partition(data)
        
        old_str = '    def match(cls, data):\n        return udev.device_is_loop(data)'
        new_str = '    def match(cls, data):\n        """Match only whole loop devices, not their partitions.\n\n        For example, match "loop2", but let PartitionDevicePopulator\n        handle "loop2p1" etc.\n        """\n        return udev.device_is_loop(data) and not udev.device_is_partition(data)'

        if old_str in content:
            new_content = content.replace(old_str, new_str)
            with open(helper_loop_py_path, "w") as f:
                f.write(new_content)
            print("Successfully patched blivet/populator/helpers/loop.py")
        else:
            print("WARNING: Could not find target string in blivet/populator/helpers/loop.py.")

    else:
        print(f"WARNING: {helper_loop_py_path} does not exist.")


    # --------------------------------------------------------------------------
    # 2.3 修改 blivet/populator/helpers/partition.py (可选，增加 log)
    # --------------------------------------------------------------------------
    helper_part_py_path = os.path.join(blivet_root, "populator/helpers/partition.py")
    if os.path.exists(helper_part_py_path):
        with open(helper_part_py_path, "r") as f:
            content = f.read()

        # 目标: 在 return 之前增加 log.debug
        # log.error("failure finding disk for %s", name)
        # return
        
        old_str = '            log.error("failure finding disk for %s", name)\n            return'
        new_str = '            log.error("failure finding disk for %s", name)\n            return\n\n        log.debug("PartitionDevicePopulator: parent disk %s, partitionable=%s, partitioned=%s, fmt=%s, fmt_supported=%s",\n                  disk.name, disk.partitionable, disk.partitioned,\n                  getattr(disk.format, "type", None), getattr(disk.format, "supported", None))'

        if old_str in content:
            new_content = content.replace(old_str, new_str)
            with open(helper_part_py_path, "w") as f:
                f.write(new_content)
            print("Successfully patched blivet/populator/helpers/partition.py")
        else:
             print("WARNING: Could not find target string in blivet/populator/helpers/partition.py.")
    else:
        print(f"WARNING: {helper_part_py_path} does not exist.")

%>

## ==============================================================================
## PART 3: Lorax 指令 (在 chroot 环境执行)
## ==============================================================================

# 重新编译 Python 字节码
# 既然我们已经确切知道 blivet 在哪里，我们可以直接编译它
# 注意：这里我们使用 chroot 内部的路径。Python代码里用的 blivet_root 包含 root 前缀，
# 我们需要把它剥离成 chroot 内的路径。

<%
# 计算 chroot 内的 blivet 路径
chroot_blivet_path = "/" + os.path.relpath(blivet_root, root)

# 生成用于修复 mount.ntfs 的辅助 Python 脚本
# 我们将代码逻辑保留在这里以保证可读性，但通过 base64 编码传递给 runcmd 执行
fix_ntfs_code = r"""
import os
import pathlib

import base64

# 目标文件路径
p = pathlib.Path("/usr/sbin/mount.ntfs")

# 如果文件存在或是一个符号链接，先删除它
# 这一步至关重要，防止写入操作跟随软链接修改了错误的目标（如 /bin/ntfs-3g）
if p.exists() or p.is_symlink():
    try:
        p.unlink()
    except OSError:
        os.remove(p)

# 确保目录存在
p.parent.mkdir(parents=True, exist_ok=True)

# 写入 wrapper 脚本内容
script_content = '''#!/bin/sh
# Try to locate a usable mount binary.
if command -v mount >/dev/null 2>&1; then
    MNT="$(command -v mount)"
elif [ -x /usr/bin/mount ]; then
    MNT="/usr/bin/mount"
elif [ -x /bin/mount ]; then
    MNT="/bin/mount"
else
    MNT="mount"
fi
exec "$MNT" -t ntfs3 "$@"
'''

p.write_text(script_content)
os.chmod(p, 0o755)
"""

# 使用 base64 编码 Python 脚本，以便在 runcmd 中安全执行
# 这种方式既不需要生成临时文件，又能保持代码在模板中的可读性
fix_ntfs_encoded = base64.b64encode(fix_ntfs_code.encode("utf-8")).decode("utf-8")
%>

runcmd python3 -m compileall -q ${chroot_blivet_path}
runcmd python3 -c "import base64; exec(base64.b64decode(b'${fix_ntfs_encoded}'))"
